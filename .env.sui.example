# =============================================================================
# MediFlow-Sui environment (Sui Overflow 2026 - Agentic Web track)
# =============================================================================
# Copy to `.env` (or merge into your existing .env) and fill in real values:
#     cp .env.sui.example .env
#
# This file lists ONLY the new variables introduced by the Sui fork. The base
# MedBand variables (AIML_API_KEY, ACTIVE_SECTOR, Band creds, DATABASE_URL,
# etc.) still live in .env.example and are unchanged.
# =============================================================================

# --- Required: Sui execution toggle -----------------------------------------
# When true, stage completions are routed through the case_router Move contract
# (core/sui_client.py) and Walrus storage (core/walrus_client.py). When false,
# the original Band / Phase-1 path runs unchanged.
SUI_MODE=true

# --- Required: Sui chain connection ------------------------------------------
# Full node RPC endpoint. Use a testnet endpoint for the hackathon demo.
#   testnet:  https://fullnode.testnet.sui.io:443
#   mainnet:  https://fullnode.mainnet.sui.io:443
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Signing key for the address the agents/coordinator transact from.
# Accepts a Sui bech32 secret key (suiprivkey1...) exported via
# `sui keytool export`. KEEP THIS SECRET - never commit a real key.
SUI_PRIVATE_KEY=suiprivkey1your-exported-private-key-here

# Published package id of the mediflow_sui Move package (from `sui client publish`).
# Leave blank to run the Sui path in dry-run mode (no on-chain submission).
SUI_PACKAGE_ID=0xyour_published_package_id_here

# --- Required: Walrus decentralized storage ----------------------------------
# Base URL of your Walrus HTTP gateway. Used as both publisher (PUT /v1/blobs)
# and aggregator (GET /v1/blobs/{id}) unless overridden below.
#   public testnet publisher example: https://publisher.walrus-testnet.walrus.space
WALRUS_API_URL=https://publisher.walrus-testnet.walrus.space

# Optional bearer token for hosted/authenticated Walrus gateways.
# Leave blank when using a public, unauthenticated Walrus endpoint.
WALRUS_API_KEY=

# --- Optional: advanced overrides (sensible defaults in code) ----------------
# Split the publisher (writes) and aggregator (reads) onto different hosts.
# If unset, both fall back to WALRUS_API_URL above.
# WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Walrus storage duration in epochs (default: 5).
# WALRUS_EPOCHS=5

# Path to the sui binary if it is not on PATH (default: "sui").
# SUI_BIN=sui

# Gas budget in MIST for each Move call (default: 100000000 = 0.1 SUI).
# SUI_GAS_BUDGET=100000000
